MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit tests / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml

# pytest-testmon test-impact DB (QS-276) — written during runs, never committed.
# QS-278: also ignore the SQLite WAL/SHM sidecars left by an interrupted run.
.testmondata
.testmondata-wal
.testmondata-shm
# QS-286: sidecar completion marker for the detached --seed-testmon refresh.
# (.testmondata.seed.log is already covered by the *.log rule below.)
.testmondata.seed-status
# QS-286 follow-up: the seed-status advisory lock held while a --seed-testmon
# refresh is in flight (sibling artifact that was missed by the rule above).
.testmondata.seed-status.lock
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

