{## SETUP OF NEEDED ENTITIES #}
{%- set all_radiateurs = namespace(sensors = []) %}
{%- set all_cumulus = namespace(sensors = []) %}
{%- set all_clims = namespace(sensors = []) %}
{%- set all_electronics = namespace(sensors = []) %}
{%- set all_additional = namespace(sensors = []) %}
{%- set all_compteurs = namespace(sensors = []) %}
{%- set all_power_raw = namespace(sensors = []) %}
{%- set additional_to_be_corrected = namespace(sensors = []) %}

{% set power_groups = [('radiateurs', all_radiateurs), ('cumulus',all_cumulus), ('electronics', all_electronics),  ('compteurs', all_compteurs), ('clim', all_clims), ('additional',all_additional),('all_measured', all_power_raw)] %}


{% set entities_netatmo = integration_entities('netatmo') %}
{%- for ent in entities_netatmo -%}
    {%- if ent.startswith('sensor.') and ent.endswith('_power')  -%}
      {%- set ent_name = ent.split('.')[1] %}
      {%- set all_power_raw.sensors = all_power_raw.sensors + [ent_name] -%}
      {%- if ent_name.startswith('cumulus')  -%}
        {%- set all_cumulus.sensors = all_cumulus.sensors + [ent_name] -%}
      {%- endif -%}
      {%- if ent_name.startswith('radiateur')  -%}
        {%- set all_radiateurs.sensors = all_radiateurs.sensors + [ent_name] -%}
      {%- endif -%}
      {%- if ent_name.startswith('compteur')  -%}
        {%- set all_compteurs.sensors = all_compteurs.sensors + [ent_name] -%}
      {%- endif -%}
      {%- if ent_name.startswith('mesure_clim')  -%}
        {%- set all_clims.sensors = all_clims.sensors + [ent_name] -%}
      {%- endif -%}
    {%- endif -%}
{%- endfor -%}


{%- set all_clims.sensors = all_clims.sensors + ['shellypro3em_2cbcbba5c4d8_total_active_power'] %}
{%- set all_clims.sensors = all_clims.sensors + ['shellypro3em_ac15187c5e58_total_active_power'] %}
{%- set all_electronics.sensors = all_electronics.sensors + ['smart_switch_2309260795056651081648e1e9dc9b9f_power'] -%}
{%- set all_electronics.sensors = all_electronics.sensors + ['setup_pc_brice_power'] -%}
{%- set all_electronics.sensors = all_electronics.sensors + ['setup_tv_apple_tv_switch_salon_power'] -%}
{%- set all_electronics.sensors = all_electronics.sensors + ['mesure_pc_switch_remi_power'] -%}
{%- set all_electronics.sensors = all_electronics.sensors + ['cam_porte_power'] -%}
{%- set all_electronics.sensors = all_electronics.sensors + ['prise_pool_house_relais_zigbee_power'] -%}



{## ADDING OTHER TO BE COUNTED HAS MEASURED POWER ##}
{%- set all_additional.sensors = all_additional.sensors + ['shellypro3em_08f9e0eb29ac_total_active_power'] -%}


{% for group_name, group_list in power_groups %}
    {%- for power in group_list.sensors %}
      {% if power not in all_power_raw.sensors %}
        {%- set all_power_raw.sensors = all_power_raw.sensors + [power] -%}
      {% endif %}
    {%- endfor -%}
{% endfor %}


{## ADDING OTHER TO BE CORRECTED POWER ##}
{%- set additional_to_be_corrected.sensors = additional_to_be_corrected.sensors + ['house_consumption_power'] -%}



{%- set round_val=0 -%}
{%- set do_correct_with_prev_value_sensors=True -%}


{%- set all_power_to_be_corrected = namespace(sensors = []) %}
{%- for power in all_power_raw.sensors %}
{%- set all_power_to_be_corrected.sensors = all_power_to_be_corrected.sensors + [power] -%}
{% endfor %}
{%- for power in additional_to_be_corrected.sensors %}
{%- set all_power_to_be_corrected.sensors = all_power_to_be_corrected.sensors + [power] -%}
{% endfor %}

{% set postfix_power = "_corrected" %}

{## REMOVE ALL CORRECTED SENSORS ##}
{%- set all_power_to_be_corrected = namespace(sensors = []) %}
{% set postfix_power = "" %}

input_boolean:
  legrand_ticker:
    name: "Legrand Ticker"
  legrand_pumpkin:
    name: "Legrand Pumpkin"
  homekit_hub_alive:
    name: "HomeKit Hub Alive"
    
template:
  - trigger:
      - platform: time_pattern
        seconds: "/15"
      - platform: state
        entity_id:
          - input_boolean.legrand_pumpkin
          - input_boolean.homekit_hub_alive
          - input_boolean.legrand_ticker
    binary_sensor:
      - name: "Legrand HomeKit link healthy"
        unique_id: legrand_homekit_link_healthy
        state: {{ "'{{ (now() - states.input_boolean.legrand_pumpkin.last_changed).total_seconds() < 90 }}'" }}
        availability: {{ "'{{ states.input_boolean.legrand_pumpkin is not none }}'" }}

      - name: "HomeKit hub healthy"
        unique_id: homekit_hub_healthy
        state: {{ "'{{ (now() - states.input_boolean.homekit_hub_alive.last_changed).total_seconds() < 90 }}'" }}
        availability: {{ "'{{ states.input_boolean.homekit_hub_alive is not none }}'" }}
  - switch:
      - unique_id: cumulus_enfants_sauter_boost_switch
        turn_on:
        - action: number.set_value
          target:
            entity_id:
            - number.cumulus_enfants_boost_mode_duration
          data:
            value: '1'
        turn_off:
        - action: number.set_value
          target:
            entity_id:
            - number.cumulus_enfants_boost_mode_duration
          data:
            value: '0'
        default_entity_id: switch.cumulus_enfants_sauter_boost_switch
        name: Boost Cumulus Enfants
        state: {{ "'{{ not is_state(''number.cumulus_enfants_boost_mode_duration'', ''0'') }}'" }}
  - switch:
      - unique_id: radiateur_serviettes_parents_qs_switch
        turn_on:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_des_parents
          data:
            hvac_mode: heat
        turn_off:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_des_parents
          data:
            hvac_mode: auto
        default_entity_id: switch.radiateur_serviettes_parents_qs_switch
        name: QS Radiateur Serviette Parents
        state: {{ "'{{ is_state(''climate.salle_de_bains_des_parents'', ''heat'') }}'" }}
  - switch:
      - unique_id: radiateur_serviettes_enfants_qs_switch
        turn_on:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_des_enfants
          data:
            hvac_mode: heat
        turn_off:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_des_enfants
          data:
            hvac_mode: auto
        default_entity_id: switch.radiateur_serviettes_enfants_qs_switch
        name: QS Radiateur Serviette Enfants
        state: {{ "'{{ is_state(''climate.salle_de_bains_des_enfants'', ''heat'') }}'" }}
  - switch:
      - unique_id: radiateur_serviettes_arthur_qs_switch
        turn_on:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_darthur
          data:
            hvac_mode: heat
        turn_off:
        - action: climate.set_hvac_mode
          target:
            entity_id:
            - climate.salle_de_bains_darthur
          data:
            hvac_mode: auto
        default_entity_id: switch.radiateur_serviettes_arthur_qs_switch
        name: QS Radiateur Serviette Arthur
        state: {{ "'{{ is_state(''climate.salle_de_bains_darthur'', ''heat'') }}'" }}
  - binary_sensor:
      - name: twingo_fixed_plug
        unique_id: twingo_fixed_plug
        state: >
            {{ "{% set is_plugged = 'off' %}"}}
            {{ "{% if is_state('sensor.gm367np_plug_state', ['plugged', 'plugged_waiting_for_charge']) %}"}}
            {{ "    {% set is_plugged = 'on' %}"}}
            {{ "{% elif is_state('binary_sensor.gm367np_plug', ['on']) %}"}}
            {{ "    {% set is_plugged = 'on' %}"}}
            {{ "{% elif is_state('sensor.gm367np_charge_state', ['waiting_for_current_charge','charge_in_progress','waiting_for_a_planned_charge','charge_ended']) %}"}}
            {{ "    {% set is_plugged = 'on' %}"}}
            {{ "{% endif %}"}}
            {{ "{{is_plugged}}"}}
        availability: >
            {{ "{{ (not is_state('sensor.gm367np_charge_state', 'unavailable')) or (is_state('sensor.gm367np_plug_state', ['plugged', 'plugged_waiting_for_charge'])) }}"}}
  - sensor:
      - name: twingo_fixed_perc_battery
        unique_id: twingo_fixed_perc_battery
        state_class: measurement
        device_class: battery
        unit_of_measurement: '%'
        state: >
          {{ "{{ states('sensor.gm367np_battery') }}"}}
        availability: >
          {{ "{% set is_available = false -%}"}}
          {{ "{% if states('sensor.gm367np_battery')|is_number -%}" }}
          {{ "    {% set is_available = true -%}" }}
          {{ "    {% if states('sensor.gm367np_battery')|float(0)  == 100 -%}" }}
          {{ "        {% set charging_status = states('sensor.gm367np_charge_state') -%}" }}
          {{ "        {% set plug_status = states('sensor.gm367np_plug_state') -%}" }}
          {{ "        {% set battery_autonomy = states('sensor.gm367np_battery_autonomy') -%}" }}          
          {{ "        {% if  charging_status is none or is_state('sensor.gm367np_charge_state',['unavailable', 'unknown', 'none', 'waiting_for_current_charge']) -%}" }}
          {{ "            {% set is_available = false -%}" }}
          {{ "        {% elif plug_status is none or is_state('sensor.gm367np_plug_state',['unavailable', 'unknown', 'none', 'plug_unknown']) -%}" }}
          {{ "            {% set is_available = false -%}" }}
          {{ "        {% elif battery_autonomy is none or is_state('sensor.gm367np_battery_autonomy',['unavailable', 'unknown', 'none']) or (battery_autonomy|float(2) < 170) -%}" }}
          {{ "            {% set is_available = false -%}" }}
          {{ "        {% endif -%}" }}
          {{ "    {% endif -%}" }}
          {{ "{% endif -%}" }}
          {{ "{{is_available}}"}}
  - sensor:
      - name: house_consumption_power
        unique_id: house_consumption_power
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{ "{% set inv_active_power = states('sensor.inverter_active_power')|float(0) %}" }}
          {{ "{% set pm_active_power = states('sensor.emma_active_power')|float(0) %}" }}
          {{ "{{ (inv_active_power + pm_active_power)|float(0)|round(0) }}"}}
        availability: >
          {{ "{{ (states('sensor.inverter_active_power')|is_number) and (states('sensor.emma_active_power')|is_number) }}" }}
  - sensor:
      - name: power_meter_active_power_inverted
        unique_id: power_meter_active_power_inverted
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{ "{% set pm_active_power = states('sensor.emma_active_power')|float(0) %}" }}
          {{ "{{ (0 - pm_active_power)|float(0)|round(0) }}" }}
        availability: >
          {{ "{{ (states('sensor.emma_active_power')|is_number) }}" }}
  - sensor:
      - name: batteries_charge_discharge_power_inverted
        unique_id: batteries_charge_discharge_power_inverted
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{ "{% set pm_charge_power = states('sensor.batteries_charge_discharge_power')|float(0) %}" }}
          {{ "{{ (0 - pm_charge_power)|float(0)|round(0) }}" }}
        availability: >
          {{ "{{ (states('sensor.batteries_charge_discharge_power')|is_number) }}" }}          
{%- for power in all_power_to_be_corrected.sensors %}
  - trigger:
      - platform: state
        entity_id: {{"sensor." + power }}
        not_to:
          - unknown
          - unavailable
    sensor:
     -  name: {{power}}{{postfix_power}}
        unique_id: {{power}}{{postfix_power}}
        state: >
          {{ "{{ trigger.to_state.state }}" }}
        state_class: measurement
        device_class: power
        unit_of_measurement: W
{%- endfor %}
{%- for group_name, group_list in power_groups %}
  - sensor:
     -  name: Total {{group_name}} power 
        unique_id: total_{{group_name}}_power
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{'{{ ( 0.0 '}}
          {% for power in group_list.sensors -%}
          {{ '+ states("sensor.' + power + postfix_power + '") |float(default=0)'}}
          {% endfor -%}
          {{ ') | round(' + round_val | string + ') }}' }}
{%- endfor %}
  - sensor:
     -  name: Total rad and clim power 
        unique_id: total_rad_and_clim_power
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{'{{ (states("sensor.total_radiateurs_power") |float(default=0)'}}
          {{ '+ states("sensor.total_clim_power") |float(default=0)'}}
          {{ ') | round(' + round_val | string + ') }}' }}
  - sensor:
     -  name: Total the rest measured power 
        unique_id: total_the_rest_measured_power
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{'{{ (states("sensor.total_all_measured_power") |float(default=0)'}}
          {%- for group_name, group_list in power_groups %}
          {% if group_name != 'all_measured' -%}
          {{ '- states("sensor.total_' + group_name + '_power") |float(default=0)'}}
          {%- endif -%}
          {% endfor -%}
          {{ ') | round(' + round_val | string + ') }}' }}
  - sensor:
     -  name: Total left unmeasured power 
        unique_id: total_left_unmeasured_power
        state_class: measurement
        device_class: power
        unit_of_measurement: W
        state: >
          {{'{{ (states("sensor.house_consumption_power' + postfix_power + '") |float(default=0)'}}
          {{ '- states("sensor.total_all_measured_power") |float(default=0)'}}
          {{ ') | round(' + round_val | string + ') }}' }}
        
homekit:
  - filter:
     include_entities:
        - sensor.porte_dentree_battery
        - cover.store
        - climate.salon
        - climate.cuisine_2
        - climate.quentin_2
        - climate.brice_2
        - climate.arthur_2
        - climate.remi_2
        - climate.clim_chambre_parents_room_temperature
        - climate.clim_pool_house_room_temperature
        - button.livebox_fibre_livebox_restart
        - select.pool_filtration_mode
        - vacuum.peyrebelle_pool_robot
        - remote.tv_salon
        - media_player.tv_salon
        - vacuum.my_pool_robot_2
        - input_boolean.legrand_ticker
        - input_boolean.legrand_pumpkin
        - input_boolean.homekit_hub_alive
        
     include_entity_globs:
        - binary_sensor.pool*
        - sensor.pool*
        - select.model_3_de_thomas_*
        - button.model_3_de_thomas_*
        - update.model_3_de_thomas_*
        - sensor.model_3_de_thomas_*
        - lock.model_3_de_thomas_*
        - cover.model_3_de_thomas_*
        - binary_sensor.model_3_de_thomas_*
        - device_tracker.model_3_de_thomas_*
        - switch.model_3_de_thomas_*
        - number.model_3_de_thomas_*
        - climate.model_3_de_thomas_*

    entity_config:
      cover.store:
        linked_battery_sensor: sensor.store_battery
        name: Store
      lock.porte_dentree:
        linked_battery_sensor: sensor.porte_dentree_battery
      vacuum.my_pool_robot_2:
        name: Robot Piscine
      remote.tv_salon:
        name: TV Salon Switch
      media_player.tv_salon:
        name: TV Salon
